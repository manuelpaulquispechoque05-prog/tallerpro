        <mxCell id="1" parent="0" />
        <UserObject label="" mermaidData="{&#xa;  &quot;data&quot;: &quot;classDiagram\n    direction TB\n    class Usuario {\n        +Integer id\n        +String nombre\n        +String email\n        +String password\n        +Boolean estado\n        +Integer rol_id\n        +login()\n        +logout()\n        +cambiarPassword()\n    }\n    class Rol {\n        +Integer id\n        +String nombre\n        +String descripcion\n        +asignarPermiso()\n    }\n    class Permiso {\n        +Integer id\n        +String accion\n    }\n    Usuario \&quot;*\&quot; -- \&quot;1\&quot; Rol : Tiene &gt;\n    Rol \&quot;*\&quot; -- \&quot;*\&quot; Permiso : Posee &gt;\n\n    class Cliente {\n        +Integer id\n        +String ci_nit\n        +String nombreCompleto\n        +String telefono\n        +String direccion\n        +registrarCliente()\n    }\n    class Vehiculo {\n        +Integer id\n        +String placa\n        +String chasis\n        +Integer año\n        +String color\n        +Integer cliente_id\n        +Integer modelo_id\n        +registrarVehiculo()\n    }\n    class MarcaVehiculo {\n        +Integer id\n        +String nombre\n    }\n    class ModeloVehiculo {\n        +Integer id\n        +String nombre\n        +Integer marca_id\n    }\n    Cliente \&quot;1\&quot; -- \&quot;*\&quot; Vehiculo : Dueño de &gt;\n    Vehiculo \&quot;*\&quot; -- \&quot;1\&quot; ModeloVehiculo : Es un &gt;\n    ModeloVehiculo \&quot;*\&quot; -- \&quot;1\&quot; MarcaVehiculo : Pertenece a &gt;\n\n    class OrdenTrabajo {\n        +Integer id\n        +Date fechaIngreso\n        +Date fechaEstimadaEntrega\n        +String estado\n        +Integer kilometraje\n        +Integer vehiculo_id\n        +Integer usuario_id\n        +crearOrden()\n        +cambiarEstado()\n    }\n    class DetalleOrdenTrabajo {\n        +Integer id\n        +Integer cantidad\n        +Float subtotal\n        +Integer orden_id\n        +Integer servicio_id\n        +Integer repuesto_id\n        +Integer mecanico_id\n        +calcularSubtotal()\n    }\n    class Servicio {\n        +Integer id\n        +String nombre\n        +Float precioBase\n        +Float tiempoEstimado\n        +Integer tipo_servicio_id\n    }\n    class TipoServicio {\n        +Integer id\n        +String categoria\n    }\n    Vehiculo \&quot;1\&quot; -- \&quot;*\&quot; OrdenTrabajo : Recibe &gt;\n    OrdenTrabajo \&quot;1\&quot; -- \&quot;*\&quot; DetalleOrdenTrabajo : Compuesto por &gt;\n    DetalleOrdenTrabajo \&quot;*\&quot; -- \&quot;1\&quot; Servicio : Incluye &gt;\n    Servicio \&quot;*\&quot; -- \&quot;1\&quot; TipoServicio : Clasificado en &gt;\n\n    class Mecanico {\n        +Integer id\n        +String nombreCompleto\n        +Boolean disponible\n        +Integer sucursal_id\n    }\n    class Especialidad {\n        +Integer id\n        +String nombre\n    }\n    class Sucursal {\n        +Integer id\n        +String nombre\n        +String direccion\n    }\n    DetalleOrdenTrabajo \&quot;*\&quot; -- \&quot;1\&quot; Mecanico : Ejecutado por &gt;\n    Mecanico \&quot;*\&quot; -- \&quot;*\&quot; Especialidad : Especializado en &gt;\n    Mecanico \&quot;*\&quot; -- \&quot;1\&quot; Sucursal : Trabaja en &gt;\n\n    class Repuesto {\n        +Integer id\n        +String codigoBarras\n        +String nombre\n        +Float precioVenta\n        +Integer proveedor_id\n    }\n    class Inventario {\n        +Integer id\n        +Integer stockActual\n        +Integer stockMinimo\n        +Integer repuesto_id\n        +Integer sucursal_id\n        +actualizarStock()\n    }\n    class MovimientoInventario {\n        +Integer id\n        +String tipo\n        +Integer cantidad\n        +Date fecha\n        +Integer inventario_id\n    }\n    class Proveedor {\n        +Integer id\n        +String nombreEmpresa\n    }\n    DetalleOrdenTrabajo \&quot;*\&quot; -- \&quot;0..1\&quot; Repuesto : Utiliza &gt;\n    Repuesto \&quot;1\&quot; -- \&quot;1\&quot; Inventario : Registrado en &gt;\n    Inventario \&quot;1\&quot; -- \&quot;*\&quot; MovimientoInventario : Genera &gt;\n    Repuesto \&quot;*\&quot; -- \&quot;1\&quot; Proveedor : Suministrado por &gt;\n    Inventario \&quot;*\&quot; -- \&quot;1\&quot; Sucursal : Ubicado en &gt;\n\n    class Pago {\n        +Integer id\n        +Date fechaPago\n        +Float montoPagado\n        +Integer orden_id\n        +Integer metodo_pago_id\n        +procesarTransaccion()\n    }\n    class MetodoPago {\n        +Integer id\n        +String nombre\n    }\n    class Factura {\n        +Integer id\n        +String nitCliente\n        +Float total\n        +Date fechaEmision\n        +Integer orden_id\n    }\n    OrdenTrabajo \&quot;1\&quot; -- \&quot;*\&quot; Pago : Saldada con &gt;\n    Pago \&quot;*\&quot; -- \&quot;1\&quot; MetodoPago : Realizado vía &gt;\n    OrdenTrabajo \&quot;1\&quot; -- \&quot;0..1\&quot; Factura : Facturada en &gt;\n\n    class Reporte {\n        +Integer id\n        +String tipoReporte\n        +Date fechaGeneracion\n        +generarReporte()\n    }\n    class Auditoria {\n        +Integer id\n        +String accion\n        +String tablaAfectada\n        +Date fecha\n        +Integer usuario_id\n    }\n    Usuario \&quot;1\&quot; -- \&quot;*\&quot; Auditoria : Realiza &gt;\n\n    class Cita {\n        +Integer id\n        +DateTime fechaHora\n        +String motivo\n        +Integer cliente_id\n        +Integer estado_cita_id\n        +agendarCita()\n    }\n    class EstadoCita {\n        +Integer id\n        +String estado\n    }\n    Cliente \&quot;1\&quot; -- \&quot;*\&quot; Cita : Agenda &gt;\n    Cita \&quot;*\&quot; -- \&quot;1\&quot; EstadoCita : Tiene &gt;\n\n    class Garantia {\n        +Integer id\n        +Integer mesesCobertura\n        +String condiciones\n        +Integer detalle_orden_id\n        +verificarVigencia()\n    }\n    class ReclamoGarantia {\n        +Integer id\n        +Date fechaReclamo\n        +String descripcionFalla\n        +Integer garantia_id\n    }\n    DetalleOrdenTrabajo \&quot;1\&quot; -- \&quot;0..1\&quot; Garantia : Cubierto por &gt;\n    Garantia \&quot;1\&quot; -- \&quot;*\&quot; ReclamoGarantia : Presenta &gt;\n\n    class Promocion {\n        +Integer id\n        +String nombre\n        +Float porcentajeDescuento\n        +Date fechaInicio\n        +Date fechaFin\n    }\n    Servicio \&quot;*\&quot; -- \&quot;0..1\&quot; Promocion : Aplica &gt;\n        &quot;,&#xa;  &quot;config&quot;: null&#xa;}" id="dlb3jorxjBVMuTJ3VKnV-1">
